import java.util.Stack;

public class Main {
    public static void main(String[] args) {

        Stack<Integer> stack = new Stack<>();

        // Insertion (Push)
        stack.push(10);
        stack.push(20);
        stack.push(30);
        stack.push(40);
        stack.push(50);

        System.out.println("Stack: " + stack);

        // Find middle value
        int midIndex = stack.size() / 2;
        int midValue = stack.get(midIndex);

        System.out.println("Middle Value: " + midValue);

        // Delete (Pop top element)
        int deleted = stack.pop();

        System.out.println("Deleted Element: " + deleted);
        System.out.println("Stack after delete: " + stack);
    }
}
